# Plantilla de variables para 06-rag
# Copia este archivo a .env (misma carpeta) y mete tus keys reales.
# .env está en .gitignore. NUNCA lo commitees.

# Para llamar a Claude (igual que el resto de ejemplos)
ANTHROPIC_API_KEY=

# Opcional. Si no lo defines, el ejemplo usa claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Para generar embeddings. Conseguir en https://platform.openai.com/api-keys
# Este ejemplo usa text-embedding-3-small (~$0.02 / millón de tokens).
OPENAI_API_KEY=
