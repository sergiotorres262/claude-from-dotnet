# Plantilla de variables de entorno para claude-from-dotnet
# Copia este archivo a .env (mismo directorio) y rellena los valores reales.
# .env esta en .gitignore — NUNCA lo commitees.

# API key de Anthropic Claude — obligatoria en todos los ejemplos
# Conseguir en: https://console.anthropic.com (Settings -> API Keys)
ANTHROPIC_API_KEY=

# Modelo de Claude a usar (opcional, default claude-sonnet-4-6)
# Ver lista en: https://docs.claude.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-4-6

# API key de OpenAI — SOLO para el ejemplo 06 (embeddings)
# Conseguir en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
