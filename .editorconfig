# EditorConfig para claude-from-dotnet
# https://editorconfig.org
# Reglas de estilo C# uniformes para todos los ejemplos del repo

root = true

# Defaults para todos los archivos
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown: permitir trailing whitespace (saltos de linea con doble espacio)
[*.md]
trim_trailing_whitespace = false

# YAML / JSON / config: 2 espacios
[*.{yml,yaml,json}]
indent_size = 2

# Archivos C#
[*.cs]
indent_size = 4

# Namespaces file-scoped (C# 10+)
csharp_style_namespace_declarations = file_scoped:warning

# var cuando el tipo es obvio del RHS
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_elsewhere = true:silent

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# Naming: PascalCase para tipos / metodos / propiedades publicas
dotnet_naming_rule.types_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.types.applicable_kinds = class,struct,interface,enum,delegate
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# Naming: campos privados con _camelCase
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.style = underscore_camel_case_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case_style.capitalization = camel_case
dotnet_naming_style.underscore_camel_case_style.required_prefix = _

# Archivos de proyecto / solucion
[*.{csproj,sln,props,targets}]
indent_size = 2
